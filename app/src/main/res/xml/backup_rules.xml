<?xml version="1.0" encoding="utf-8"?>
<!--
   Sauvegarde Auto (Android 12 et moins) : on inclut la base de données
   (la collection), les préférences (prénom, réglages) et le DataStore
   (drapeau seed_imported, réglages), stocké dans files/datastore/.
   Le cache des sorties (releases_cache.json) n'est pas sauvegardé :
   il sera simplement re-téléchargé.
-->
<full-backup-content>
    <include domain="database" path="." />
    <include domain="sharedpref" path="." />
    <include domain="file" path="datastore/" />
    <exclude domain="file" path="releases_cache.json" />
</full-backup-content>
