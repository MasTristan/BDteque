<?xml version="1.0" encoding="utf-8"?>
<!--
   Règles de sauvegarde/transfert (Android 12+).
   Voir backup_rules.xml pour le détail des inclusions/exclusions.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="datastore/" />
        <exclude domain="file" path="releases_cache.json" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="datastore/" />
        <exclude domain="file" path="releases_cache.json" />
    </device-transfer>
</data-extraction-rules>
